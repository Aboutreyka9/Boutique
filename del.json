SELECT en.*,ar.libelle_article AS article,ac.created_at d_vente FROM entree en 
INNER JOIN article ar ON ar.ID_article = en.article_id 
INNER JOIN achat ac ON ac.code_achat=en.achat_id
GROUP BY ac.created_at, ar.ID_article
ORDER BY ac.created_at DESC;

SELECT so.*,ar.libelle_article AS article,ve.created_at d_vente ,ve.etat_vente AS e_v FROM sortie so 
INNER JOIN article ar ON ar.ID_article = so.article_id 
INNER JOIN vente ve ON ve.code_vente=so.vente_id
GROUP BY ve.created_at, ar.ID_article
HAVING e_v=1
ORDER BY ve.created_at DESC;





SELECT ar.ID_article, ar.libelle_article article, SUM(so.qte) so_qte, SUM(so.prix_vente*so.qte) so_montant FROM article ar
        INNER JOIN sortie so ON so.article_id = ar.ID_article 
        GROUP BY ar.ID_article;

        // View bilan sortie
        CREATE VIEW bilan_sortie (ID_article,article,so_qte,so_montant)
                AS SELECT ar.ID_article, ar.libelle_article article, SUM(so.qte) so_qte, SUM(so.prix_vente*so.qte) so_montant FROM article ar
                INNER JOIN sortie so ON so.article_id = ar.ID_article 
                WHERE so.etat_sortie =1
                GROUP BY ar.ID_article;

        // View bilan entree

        CREATE VIEW bilan_entree (ID_article,article,en_qte,en_montant)
                AS SELECT ar.ID_article, ar.libelle_article article, SUM(en.qte) en_qte, SUM(en.prix_achat*en.qte) en_montant FROM article ar
                INNER JOIN entree en ON en.article_id = ar.ID_article 
                WHERE en.etat_entree =1
                GROUP BY ar.ID_article;


        SELECT be.ID_article,be.article ,be.en_qte,be.en_montant, bs.so_qte,bs.so_montant FROM bilan_sortie bs
RIGHT JOIN bilan_entree be ON be.ID_article = bs.ID_article;

SELECT be.ID_article,be.article ,be.en_qte,be.en_montant,
IF(bs.so_qte IS NULL,0,bs.so_qte) AS so_qte,
IF(bs.so_montant IS NULL,0,bs.so_montant) AS so_montant
FROM bilan_sortie bs
RIGHT JOIN bilan_entree be ON be.ID_article = bs.ID_article;

// View Bilan Comptabilite

CREATE view comptabilite (id_article,article,depenses,ventes,qte_reste,mt_reste,gain) AS
SELECT be.ID_article, be.article Article ,be.en_montant Depense,
IF(bs.so_montant IS NULL,0,bs.so_montant) AS Vente,
(be.en_qte - IF(bs.so_qte IS NULL,0,bs.so_qte)) AS QteReste,
((be.en_qte - IF(bs.so_qte IS NULL,0,bs.so_qte))* ar.prix_article) AS mtRest,
(IF(bs.so_montant IS NULL,0,bs.so_montant) + ((be.en_qte - IF(bs.so_qte IS NULL,0,bs.so_qte))* ar.prix_article) -be.en_montant) AS Gain
FROM bilan_sortie bs
RIGHT JOIN bilan_entree be ON be.ID_article = bs.ID_article
INNER JOIN article ar ON ar.ID_article = be.ID_article;


// View change etat vente
CREATE VIEW change_etat_vente (id_vente,etat_vente,code_vente) AS 
SELECT ve.ID_vente,ve.etat_vente,ve.code_vente  FROM vente ve 
INNER JOIN sortie so ON so.vente_id = ve.code_vente
WHERE ve.etat_vente = 1 AND ve.etat_vente > ANY (Select sor.etat_sortie from sortie sor where sor.vente_id = ve.code_vente AND sor.etat_sortie =0);


