COUNT(so.ID_sortie) article,SUM(so.prix_vente * so.qte) total, cl.nom_client,
cl.prenom_client,cl.telephone_client
FROM vente ve INNER JOIN sortie so ON so.vente_id = ve.code_vente
INNER JOIN client cl ON cl.ID_client = ve.client_id


SELECT MONTH(created_at) AS MOIS  
     , SUM(somme)  AS SMONT 
FROM  sommevente                    
GROUP BY MONTH(created_at)        
ORDER BY MONTH(created_at) ASC;



SELECT WEEK(ve.created_at) periode, DAY(ve.created_at) jour, SUM(so.prix_vente * qte)  AS total 
        FROM sortie so INNER JOIN vente ve ON ve.code_vente = so.vente_id
        GROUP BY DAY(ve.created_at) HAVING  periode = 46
        ORDER BY WEEK(ve.created_at), DAY(ve.created_at) DESC LIMIT 7;


// Vente par article et mois
        SELECT DISTINCT ar.libelle_article art,MONTHNAME(ve.created_at) periode, SUM(so.prix_vente * qte)  AS total 
        FROM sortie so INNER JOIN article ar ON ar.ID_article = so.article_id INNER JOIN vente ve ON 			       	 ve.code_vente = 	     so.vente_id
        GROUP BY ar.ID_article,MONTH(ve.created_at)
        ORDER By MONTH(ve.created_at),art;



        // BILAN VENTE ET ACHAT PAR MOIS

        SELECT ve.created_at dates, SUM(so.prix_vente) ventes,SUM(en.prix_achat) achats 
FROM vente ve, achat ac, entree en, sortie so
WHERE ve.code_vente = so.vente_id AND ac.code_achat = en.achat_id
GROUP BY MONTHNAME(ve.created_at) ORDER BY MONTH(ve.created_at) ASC;


        // BILAN VENTE ET ACHAT PAR MOIS PARt ARTICL
        SELECT ar.libelle_article,ve.created_at dates, SUM(so.prix_vente) ventes,SUM(en.prix_achat) achats 
FROM article ar 
INNER JOIN sortie so ON so.article_id = ar.ID_article 
INNER JOIN entree en ON en.article_id = ar.ID_article 
INNER JOIN vente ve ON ve.code_vente = so.vente_id
INNER JOIN achat ac ON ac.code_achat = en.achat_id
GROUP BY MONTHNAME(ve.created_at) ORDER BY MONTH(ve.created_at) ASC;

// VENTE PAR MOIS
$sql = "SELECT  
